[sub_resource type="GDScript" id="GDScript_tdnec"]
script/source = "extends AudioStreamPlayer


# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	SignalManager.reset_audio.connect(dampen)
	
func dampen(paused : bool) -> void:
	var lp_tween : Tween = create_tween()
	print(AudioServer.get_bus_effect(0, 0))
	if(paused):
		lp_tween.tween_property(AudioServer.get_bus_effect(0, 0), \"cutoff_hz\", 2000.0, 0.65)
		lp_tween.play()
	else:
		lp_tween.tween_property(AudioServer.get_bus_effect(0, 0), \"cutoff_hz\", 20500.0, 1.5)
		lp_tween.play()
"

